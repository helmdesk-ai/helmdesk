APP_NAME=HelmDesk
APP_ENV=development
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8888

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_COLOR=auto

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SCOUT_DRIVER=tntsearch

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=3000

# Real AI provider integration test
# Fill AI_REAL_PROVIDER to enable:
# php artisan test --compact --filter="check connection succeeds with a real provider configured from environment variables" tests/Feature/Admin/SystemSettings/AiProviderTest.php
#
# OpenRouter example:
# AI_REAL_PROVIDER=openrouter
# AI_REAL_PROTOCOL=openai-like
# AI_REAL_PROVIDER_NAME=OpenRouter
# AI_REAL_MODEL_ID=openai/gpt-5.4-nano
# AI_REAL_MODEL_NAME=OpenRouter GPT-5.4 Nano
# AI_REAL_KEY=sk-or-v1-your-short-lived-key
# AI_REAL_BASE_URI=https://openrouter.ai/api/v1
#
# Azure OpenAI example:
# AI_REAL_PROVIDER=azure-openai
# AI_REAL_KEY=
# AI_REAL_ENDPOINT=https://your-resource.openai.azure.com
# AI_REAL_VERSION=2024-10-21
#
# For seeded providers, AI_REAL_PROTOCOL is optional.
# For custom providers, set AI_REAL_PROTOCOL and usually AI_REAL_MODEL_ID too.
AI_REAL_PROVIDER=
AI_REAL_PROTOCOL=
AI_REAL_PROVIDER_NAME=
AI_REAL_MODEL_ID=
AI_REAL_MODEL_NAME=
AI_REAL_KEY=
AI_REAL_BASE_URI=
AI_REAL_ENDPOINT=
AI_REAL_VERSION=
AI_REAL_URL=
AI_REAL_INFERENCE_PROVIDER=

# Knowledge live integration / recall benchmark tests
#
# 这一组用例位于 tests/Feature/Knowledge/Live/，默认全部 skip。
# 开启方式（任一缺失即跳过）：
#   KNOWLEDGE_RUNTIME_LIVE=1
#   GO_RUNTIME_BASE_URL=http://127.0.0.1:8888   # 由 `make`/`composer run dev` 启动后填上
#   HELMDESK_INTERNAL_BRIDGE_TOKEN=...          # 与 Go runtime 同步的桥接 token
#   OPENROUTER_API_KEY=sk-or-v1-...             # OpenRouter 临时 key
#
# 跑法（示例）：
#   php artisan test --compact tests/Feature/Knowledge/Live
#
# 目前 rerank 仅支持 OpenRouter（/rerank 端点协议与 Cohere 一致），
# LLM / Embedding / Rerank 三种模型共用同一份 OPENROUTER_API_KEY。
KNOWLEDGE_RUNTIME_LIVE=
GO_RUNTIME_BASE_URL=
HELMDESK_INTERNAL_BRIDGE_TOKEN=
